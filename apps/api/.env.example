PORT=5000
LOG_LEVEL=debug

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Example pooler (region-specific host from dashboard): postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-here

GEMINI_API_KEY=your-gemini-api-key
ONEMIN_API_KEY=your-onemin-api-key

UMLS_META_DIR=../../data/umls-2025AB-metathesaurus-full/2025AB/META
UMLS_SAB_ALLOWLIST=SNOMEDCT_US,RXNORM,ICD10CM
EXPORT_MAX_CUIS=12000
INGEST_MAX_ROWS=14000
INGEST_BATCH_SIZE=10

# Zilliz Cloud (vector DB for RAG — replaces pgvector knowledge_base)
# Serverless HTTPS endpoints need port 443; if you omit :443, pymilvus defaults to :19530 (wrong). Ingest + Node config normalize https://host → https://host:443.
ZILLIZ_ENDPOINT=https://in01-xxxxxxxx.api.gcp-us-west1.zillizcloud.com
ZILLIZ_TOKEN=your-zilliz-api-key
ZILLIZ_COLLECTION=knowledge_base
# ZILLIZ_CONNECT_TIMEOUT=45
# ZILLIZ_HTTPS_PORT=443

# Embeddings: onnx (local Nomic ONNX, default) | openrouter
# EMBEDDING_DIM must match the model output and the Zilliz collection (default 768 for Nomic).
# If you change dim or provider, drop/recreate the collection (pnpm zilliz:setup on empty/new name) and re-ingest.
EMBEDDING_PROVIDER=onnx
EMBEDDING_DIM=768
# OPENROUTER_API_KEY=          # required when EMBEDDING_PROVIDER=openrouter — never commit; rotate if leaked
OPENROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# Optional: force Python ingest path only — openrouter | hf | torch | transformers
# INGEST_EMBED_PROVIDER=

# Required for auth: replace with a long random secret (e.g. openssl rand -base64 48). Never use this placeholder in production.
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_EXPIRES_IN=1d

# Optional: set both to seed the first user via pnpm bootstrap / seed:user. Leave empty to skip seeding.
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
